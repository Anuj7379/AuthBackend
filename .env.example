# Set to Postgres to use your production database, or leave blank for in-memory local mode
DatabaseProvider=Postgres

# Render Postgres connection string if you use a managed database on Render
# If you use Render's built-in Postgres service, Render sets DATABASE_URL automatically.
# If you want to set it manually, use either:
# ConnectionStrings__PostgresConnection=Host=YOUR_RENDER_DB_HOST;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require
# or
# PostgresConnection=Host=YOUR_RENDER_DB_HOST;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require

# Alternative Render env variable for PostgreSQL URLs
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# CORS origins for your frontend app
AllowedOrigins=https://your-frontend-url.com

# JWT values
Jwt__Key=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
Jwt__Issuer=AuthApi
Jwt__Audience=AuthApiUsers

# Render provides PORT automatically
# PORT=10000
